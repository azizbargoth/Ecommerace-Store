# Server
PORT=5000
NODE_ENV=development
TIMEZONE=Asia/Damascus    # your local timezone — see: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones

# MongoDB Atlas
MONGO_URI=mongodb://localhost:27017/EcommeraceStoreDB

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
